    "cmd /c npx tsx scripts/authoring/validate-reader-first-import.ts --section 10_Pattern_Synthesis --input content/authoring/generated/10-pattern-synthesis-leadership-approach.psv",
    "cmd /c npx tsx scripts/authoring/validate-reader-first-import.ts --section 11_Strengths --input content/authoring/generated/11-strengths-leadership-approach.psv",
    "cmd /c npx tsx scripts/authoring/validate-reader-first-import.ts --section 12_Narrowing --input content/authoring/generated/12-narrowing-leadership-approach.psv",
    "cmd /c npx tsx scripts/authoring/validate-reader-first-import.ts --section 13_Application --input content/authoring/generated/13-application-leadership-approach.psv",
