  "domainTitle": "Flow State",
  "signals": [
    {
      "key": "deep_focus",
      "label": "Deep Focus",
      "shortDefinition": "Sustained attention, depth, careful thinking, and finishing hard thinking."
    },
    {
      "key": "creative_movement",
      "label": "Creative Movement",
      "shortDefinition": "Options, reframing, experimentation, and generative thinking."
    },
    {
      "key": "physical_rhythm",
      "label": "Physical Rhythm",
      "shortDefinition": "Movement, pacing, hands-on rhythm, environment, and practical reset."
    },
    {
      "key": "social_exchange",
      "label": "Social Exchange",
      "shortDefinition": "Live thinking, feedback, shared sense-making, teaching, and testing ideas with others."
    }
  ],
  "rankRoles": [
    {
      "rank": 1,
      "role": "clearest starting point"
    },
    {
      "rank": 2,
      "role": "main shaping influence"
    },
    {
      "rank": 3,
      "role": "useful support or reset"
    },
    {
      "rank": 4,
      "role": "deliberate range to add when needed"
    }
  ],
  "scoreShapes": [
    {
      "key": "concentrated",
      "meaning": "One signal is clearly stronger. Treat rank 1 as the main route."
    },
    {
      "key": "paired",
      "meaning": "Top two signals are close and clearly ahead. Treat rank 1 and rank 2 as a close pair."
    },
    {
      "key": "graduated",
      "meaning": "Scores step down clearly. Treat the full rank order as meaningful."
    },
    {
      "key": "balanced",
      "meaning": "All four scores are close. Read rank order lightly and keep several routes available."
    }
  ],
  "sectionSequence": [
