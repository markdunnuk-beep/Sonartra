# Local-only ranked-pattern fixture database.
# This file contains no real secrets and must not be copied over production or hosted Supabase config.
#
# PowerShell one-off override:
# $env:DATABASE_URL="postgresql://sonartra_local:sonartra_local@localhost:54329/sonartra_local"
#
# Do not point the Flow State proof harness at hosted Supabase, staging, production, or any shared DB.
DATABASE_URL=postgresql://sonartra_local:sonartra_local@localhost:54329/sonartra_local

# The proof harness itself does not need Clerk/Supabase API keys.
# The Next app may still need normal local auth variables from .env.local for browser review.
NEXT_PUBLIC_APP_URL=http://localhost:3000
